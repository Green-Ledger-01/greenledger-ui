    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "target": "ES2022",
    "allowJs": true,
    "noEmit": true,
    "types": []
  },
  "include": ["vite.config.js"]
}
