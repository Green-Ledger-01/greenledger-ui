{
  "name": "greenledger",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "preview": "vite preview",
    "postinstall": "patch-package",
    "prepare": "husky",
    "type-check": "tsc --noEmit",
    "test": "echo \"No tests specified\" && exit 0",
    "pre-commit": "lint-staged",
    "validate": "npm run type-check && npm run lint && npm run build"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.0",
    "@rainbow-me/rainbowkit": "^2.2.6",
    "@tanstack/react-query": "^5.80.10",
    "@web3auth/base": "^9.7.0",
    "@web3auth/ethereum-provider": "^9.7.0",
    "@web3auth/modal": "^10.2.0",
    "@web3auth/openlogin-adapter": "^8.12.4",
    "antd": "^5.27.0",
    "buffer": "^6.0.3",
    "clsx": "^2.1.1",
    "eventemitter3": "^5.0.1",
    "lucide-react": "^0.513.0",
    "process": "^0.11.10",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.28.0",
    "viem": "^2.31.3",
    "wagmi": "^2.15.6"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "util": "^0.12.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@tailwindcss/postcss": "^4.1.10",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.14",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "eth-eip712-util": "^2.3.1",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "patch-package": "^8.0.0",
    "postcss": "^8.4.24",
    "postinstall-postinstall": "^2.1.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.3.2",
    "vite": "^6.3.5",
    "vite-plugin-node-polyfills": "^0.23.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ],
    "*.{ts,tsx}": [
      "tsc --noEmit"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
